<%- include('base', { 
    title: title,
    body: `
        <article class="blog-post">
            <h1>${title}</h1>
            <div class="blog-meta">
                Published on ${new Date(date).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                })}
                ${author ? `by ${author}` : ''}
            </div>
            ${content}
        </article>
    `
}) %> 